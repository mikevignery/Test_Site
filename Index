<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="A modern website for your brand, services, and contact information." />
  <title>Your Website Name</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <header class="hero">
    <nav>
      <h2>Your Brand</h2>
      <div>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#contact">Contact</a>
      </div>
    </nav>

    <section>
      <h1>Build Something Great</h1>
      <p>A clean, modern website for your business, team, or project.</p>
      <a class="button" href="#contact">Get Started</a>
    </section>
  </header>

  <main>
    <section id="about" class="section">
      <h2>About Us</h2>
      <p>Write a short description about who you are, what you do, and why people should trust you.</p>
    </section>

    <section id="services" class="section cards">
      <h2>What We Offer</h2>
      <div class="card">
        <h3>Service One</h3>
        <p>Describe your first service or offering.</p>
      </div>
      <div class="card">
        <h3>Service Two</h3>
        <p>Describe your second service or offering.</p>
      </div>
      <div class="card">
        <h3>Service Three</h3>
        <p>Describe your third service or offering.</p>
      </div>
    </section>

    <section id="contact" class="section">
      <h2>Contact Us</h2>
      <p>Email: yourname@email.com</p>
      <button onclick="showMessage()">Click Me</button>
      <p id="message"></p>
    </section>
  </main>

  <footer>
    <p>© 2026 Your Brand. All rights reserved.</p>
  </footer>

  <script src="script.js"></script>
</body>
</html>
